# SERVER
HOST=0.0.0.0
PORT=3000

# DATA
DATA_DIR=data
DATABASE_PATH=data/tasks.sqlite

# WORKDIR
WORKER_ID=worker-local
WORKER_LOCK_TTL_MS=300000
WORKER_POLL_INTERVAL_MS=3000

# OPENAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5.4-mini
